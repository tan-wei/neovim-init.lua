{
  "$schema": "https://raw.githubusercontent.com/sumneko/vscode-lua/master/setting/schema.json",
  "runtime": {
    "version": "LuaJIT"
  },
  "workspace": {
    "library": [
      "$VIMRUNTIME",
      "${env:XDG_DATA_HOME}/nvim/lazy/lazy.nvim",
      "${env:HOME}/.local/share/nvim/lazy/lazy.nvim",
      "${env:HOME}/Library/Application Support/nvim/lazy/lazy.nvim",
      "${env:LOCALAPPDATA}/nvim-data/lazy/lazy.nvim",
      "${3rd}/luv/library"
    ],
    "ignoreDir": []
  },
  "diagnostics.disable": [
    "missing-fields"
  ]
}
