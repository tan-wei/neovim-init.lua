# macOS-specific Ghostty settings.

font-family = Agave Nerd Font
font-family = Sarasa Gothic SC

font-size = 8

font-feature = calt
font-feature = liga
font-feature = zero

# adjust-cell-width = 0
# adjust-cell-height = 0

# freetype-load-flags = default
macos-titlebar-style = transparent
window-theme = auto