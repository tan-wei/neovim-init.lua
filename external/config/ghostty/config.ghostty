# Ghostty starter config.
#
# Ghostty does not have built-in per-OS conditionals in config files.
# To keep platform settings split out, copy one of linux.ghostty,
# macos.ghostty, or wsl.ghostty to platform.ghostty in the same directory.

config-file = ?platform.ghostty

shell-integration = detect
working-directory = inherit
term = xterm-ghostty

confirm-close-surface = true
copy-on-select = clipboard
scrollbar = never
mouse-hide-while-typing = true

cursor-style = block
cursor-style-blink = false

window-width = 120
window-height = 32
window-padding-x = 4
window-padding-y = 4
window-padding-balance = true